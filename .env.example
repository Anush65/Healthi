# Example environment variables for Healthi
# Copy this file to `.env` and fill values for local development.

# Google Gemini / Healthi AI key (client-exposed for this demo).
# Prefer `VITE_` prefix so Vite injects the value into the client.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Or if you renamed it in your workflow use:
VITE_HealthiApiKey=your_gemini_api_key_here

# Firebase configuration (required for Authentication & Firestore)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: analytics/measurement id
VITE_FIREBASE_MEASUREMENT_ID=
